# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/secure_incident
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/secure_incident_test

# Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REMEMBER_ME_EXPIRE_MINUTES=10080
PASSWORD_RESET_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["http://localhost:5173"]

# SMTP — local dev uses MailPit (docker-compose mailpit service)
# Production: set to real SMTP provider values
SMTP_HOST=mailpit #set to localhost in dev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com #change to @localhost in dev
SMTP_TLS=False

# Frontend URL (used to build password reset links)
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173
