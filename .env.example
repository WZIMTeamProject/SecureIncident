# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/secure_incident

# Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_REMEMBER_EXPIRE_MINUTES=43200
PASSWORD_RESET_EXPIRE_MINUTES=30

# Refresh-token cookie. Dev (same-site http://localhost): SameSite=lax, Secure=false.
# Production (cross-domain frontend): SameSite=none, Secure=true.
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=False

# Invitations — default expiry applied when none is supplied, and the max a caller may request
INVITE_EXPIRE_MINUTES=60
INVITE_MAX_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["http://localhost:5173"]

# SMTP — local dev uses MailPit (docker-compose mailpit service)
# Production: set to real SMTP provider values
SMTP_HOST=mailpit # "mailpit" when running in Docker, "localhost" when running backend directly on host
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com #change to @localhost in dev
SMTP_TLS=False

# Frontend URL (used to build password reset links)
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173
