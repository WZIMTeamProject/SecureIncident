              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncidentListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/my-assigned": {
      "get": {
        "tags": [
          "Incidents"
        ],
        "summary": "List incidents assigned to current user",
        "description": "Convenience endpoint for the 'my assigned incidents' view.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Incident list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncidentListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{incidentId}": {
      "get": {
        "tags": [
          "Incidents"
        ],
        "summary": "Get incident details",
        "description": "Returns main incident details without comments.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IncidentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Incident details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncidentDetailsResponse"
                }
              }
            }
          },
          "403": {
            "description": "Access denied"
          },
          "404": {
            "description": "Incident not found"
          }
        }
      }
    },
    "/incidents/{incidentId}/status": {
      "patch": {
        "tags": [
          "Incidents"
        ],
        "summary": "Change incident status",
        "description": "Updates the incident status and should create a visible entry in incident logs.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IncidentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIncidentStatusRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Status updated"
          },
          "403": {
            "description": "Access denied"
          }
        }
      }
    },
    "/incidents/{incidentId}/assignee": {
      "patch": {
        "tags": [
          "Incidents"
        ],
        "summary": "Change primary solver / assignee",
        "description": "Updates the primary assigned solver of the incident.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IncidentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIncidentAssigneeRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Assignee updated"
          },
          "403": {
            "description": "Access denied"
          }
        }
      }
    },
    "/incidents/{incidentId}/priority": {
      "patch": {
        "tags": [
          "Incidents"
        ],
        "summary": "Change incident priority",
        "description": "Updates incident priority level.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IncidentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIncidentPriorityRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Priority updated"
          },
          "403": {
            "description": "Access denied"
          }
        }
      }
    },
    "/incidents/{incidentId}/category": {
      "patch": {
        "tags": [
          "Incidents"
        ],
        "summary": "Change incident category",
        "description": "Updates the main category assigned to the incident.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IncidentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIncidentCategoryRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Category updated"
          },
