{
  "openapi": "3.0.3",
  "info": {
    "title": "Secure Incydent API - Core MVP",
    "version": "0.1.1",
    "description": "Core API draft for the first implementation stage of Secure Incydent. This version follows the domain rule that a user can belong to many projects, but only within one organization or in private projects."
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication and current session endpoints."
    },
    {
      "name": "Organization",
      "description": "Single-organization onboarding and membership endpoints."
    },
    {
      "name": "Projects",
      "description": "Project creation, listing, membership, and details."
    },
    {
      "name": "Categories",
      "description": "Project-scoped categories used to classify incidents."
    },
    {
      "name": "Roles",
      "description": "Project-scoped roles and role assignment."
    },
    {
      "name": "Incidents",
      "description": "Incident reporting, workflow, comments, and visible logs."
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register a new user account",
        "description": "Creates a new user account. After registration the user may create one organization, join one existing organization, or continue with private projects only.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          },
          "409": {
            "description": "Username or email already taken",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Log in user and create a session",
        "description": "Authenticates the user and establishes a session, for example by setting an HTTP-only cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Log out current user",
        "description": "Invalidates the current session.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/auth/request-password-reset": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Request password reset",
        "description": "Initiates password reset flow. The response should not reveal whether the account exists.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Reset request accepted"
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Reset password using reset token",
        "description": "Finalizes password reset using a previously issued reset token/code.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetConfirmRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password changed successfully"
          },
          "400": {
            "description": "Invalid or expired reset token"
          }
        }
      }
    },
    "/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current authenticated user",
        "description": "Returns the currently authenticated user resolved from the session, including the current organization id if the user belongs to one.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          }
        }
      }
    },
    "/organization": {
      "post": {
        "tags": [
          "Organization"
        ],
        "summary": "Create organization",
        "description": "Creates an organization and assigns the current user as owner/admin. This should fail if the user already belongs to another organization.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrganizationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Organization created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          },
          "409": {
            "description": "User already belongs to an organization"
          }
        }
      },
      "get": {
        "tags": [
          "Organization"
        ],
        "summary": "Get current user's organization",
        "description": "Returns the single organization the current user belongs to. If the user does not belong to any organization, return null or 404 depending on backend convention.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Organization returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganizationResponse"
                }
              }
            }
          },
          "404": {
            "description": "User does not belong to any organization"
          }
        }
      }
    },
    "/organization/invites": {
      "post": {
        "tags": [
          "Organization"
        ],
        "summary": "Create organization invite",
        "description": "Generates a one-time or limited-use invite for joining the current organization.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInviteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invite created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InviteResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organization/join": {
      "post": {
        "tags": [
          "Organization"
        ],
        "summary": "Join organization using invite token",
        "description": "Uses a valid organization invite token to join the user's single allowed organization. Should fail if the user already belongs to another organization.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinByInviteRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Joined organization successfully"
          },
          "400": {
            "description": "Invalid or expired invite"
          },
          "409": {
            "description": "User already belongs to an organization"
          }
        }
      }
    },
    "/projects": {
      "post": {
        "tags": [
          "Projects"
        ],
        "summary": "Create project",
        "description": "Creates a project. Project scope can be PRIVATE or ORGANIZATION. A user may have many projects, but organization projects must belong to the user's single organization.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "List projects visible to current user",
        "description": "Returns private projects and organization projects visible to the current user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "PRIVATE",
                "ORGANIZATION"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects/{projectId}": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "Get project details",
        "description": "Returns project metadata visible to the current user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "responses": {
          "200": {
            "description": "Project details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "403": {
            "description": "Access denied"
          },
          "404": {
            "description": "Project not found"
          }
        }
      },
      "patch": {
        "tags": [
          "Projects"
        ],
        "summary": "Update project metadata",
        "description": "Allows authorized users to update project name and description.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProjectRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Project updated"
          },
          "403": {
            "description": "Access denied"
          }
        }
      }
    },
    "/projects/{projectId}/members": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "List project members",
        "description": "Returns project members with their single assigned role in that project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "responses": {
          "200": {
            "description": "Member list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectMemberListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Projects"
        ],
        "summary": "Add user to project",
        "description": "Adds a user to a project and assigns exactly one role in that project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddProjectMemberRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "User added to project"
          },
          "403": {
            "description": "Access denied"
          },
          "409": {
            "description": "User already belongs to project"
          }
        }
      }
    },
    "/projects/{projectId}/members/{userId}/role": {
      "patch": {
        "tags": [
          "Projects"
        ],
        "summary": "Change user's role in project",
        "description": "Changes the single assigned role of a project member.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignRoleRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Role updated"
          },
          "403": {
            "description": "Access denied"
          }
        }
      }
    },
    "/projects/{projectId}/categories": {
      "get": {
        "tags": [
          "Categories"
        ],
        "summary": "List project categories",
        "description": "Returns categories available in a project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "responses": {
          "200": {
            "description": "Category list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoryListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Categories"
        ],
        "summary": "Create project category",
        "description": "Creates a category available for incidents in the project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCategoryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Category created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects/{projectId}/roles": {
      "get": {
        "tags": [
          "Roles"
        ],
        "summary": "List project roles",
        "description": "Returns roles available in the given project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "responses": {
          "200": {
            "description": "Role list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Roles"
        ],
        "summary": "Create custom project role",
        "description": "Creates a custom role with boolean permissions in the given project.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoleRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Role created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects/{projectId}/incidents": {
      "get": {
        "tags": [
          "Incidents"
        ],
        "summary": "List incidents in project",
        "description": "Returns incidents visible to the current user in the selected project. Supports filtering and pagination.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/IncidentStatus"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "priority",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/IncidentPriority"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "assigneeId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Incident list returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncidentListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Incidents"
        ],
        "summary": "Create incident",
        "description": "Creates a new incident in the selected project. The field name is title, not name.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIncidentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Incident created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedIdResponse"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/my-reported": {
      "get": {
        "tags": [
          "Incidents"
        ],
        "summary": "List incidents reported by current user",
        "description": "Convenience endpoint for the 'my reported incidents' view.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Incident list returned",
